generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  CREATOR
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  role        Role
  
  // Общие поля
  firstName   String
  lastName    String?
  avatarUrl   String?
  age         Int?
  
  // Поля Создателя
  category    String?  // Сфера деятельности (Разработка, Дизайн и т.д.)
  experience  String?  // Опыт работы
  description String?  // Описание навыков
  
  // Связи
  jobsCreated Job[]    @relation("ClientJobs")
  responses   Response[]
  services    Service[] // Посты с услугами Создателя

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  budget      String?
  deadline    String?
  category    String   // Сфера (фильтр)
  photos      String[] // URL фотографий
  
  clientId    String
  client      User     @relation("ClientJobs", fields: [clientId], references: [id])
  
  responses   Response[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  photos      String[] // Фотографии выполненных проектов
  category    String   // Сфера (фильтр)
  
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Response {
  id          String   @id @default(cuid())
  message     String
  
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])

  createdAt   DateTime @default(now())
}
